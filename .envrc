# Project envrc — loaded by Grok when [session] load_envrc = true
# Provides CA certs, user-space PATH, LD_LIBRARY_PATH for tools/MCP.

# shellcheck source=/dev/null
. "${HOME}/.grok/env.sh"

# Grok env puts /usr/local/bin early (legacy @mariozechner/pi-coding-agent 0.70.x).
# Prefer npm-global @earendil-works/pi-coding-agent (0.80+).
export PATH="${HOME}/.npm-global/bin:${PATH}"
